<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- DELIBERATELY ABSENT: android.permission.INTERNET (CROSS-01) -->
    <!-- Phase 4 declares but does NOT request READ_MEDIA_AUDIO; Phase 5 wires the runtime grant. -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Phase 5: PlaybackService is a foreground service of type mediaPlayback (Pitfall 2 — mandatory on Android 14+). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Required for ExoPlayer.setWakeMode(WAKE_MODE_LOCAL). Without this the
         player decoder thread may stall when the screen turns off, manifesting
         as music stopping mid-track on GrapheneOS / aggressively-doze-managed
         devices. WAKE_MODE_LOCAL holds a partial wake-lock only while playback
         is active; pause / stop releases it. Audio-only — no screen wake. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".NocturneApp"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="false"
        android:theme="@style/Theme.Nocturne"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Nocturne">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Phase 5: Media3 playback service. Bound to MediaController via the
             MediaSessionService action filter; system UI / BT routes through it. -->
        <!-- exported=true is required by Media3: system UI, BT routes, and
             MediaButton bind via MediaSessionService action. No additional
             permission gate is appropriate (every app on the device is allowed
             to drive media keys). Lint warning suppressed by design. -->
        <service
            android:name=".player.PlaybackService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!-- Phase 5: MediaButtonReceiver — required for onPlaybackResumption
             (RESEARCH.md Pitfall 3: declaring it without implementing
             onPlaybackResumption throws UnsupportedOperationException at runtime). -->
        <receiver
            android:name="androidx.media3.session.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
